"""
Snakemake workflow for training experiments.

Reads experiments.json and expands parameter grids into reference-set
construction and model training rules.

Usage:
    # Run a specific experiment
    snakemake -s snakemake/onsides/train/Snakefile --config experiment=lr_bw -j1

    # Run all experiments
    snakemake -s snakemake/onsides/train/Snakefile --config experiment=all -j1

    # Run a subset of experiments (comma-separated)
    snakemake -s snakemake/onsides/train/Snakefile --config experiment=flag_baseline,flag1_clean -j1

    # Dry-run to see what would execute
    snakemake -s snakemake/onsides/train/Snakefile --config experiment=all -n
"""

import json
import itertools
import math
from pathlib import Path

import numpy as np


# ---------------------------------------------------------------------------
# Load experiment configuration
# ---------------------------------------------------------------------------

EXPERIMENTS_FILE = Path("experiments.json")

with open(EXPERIMENTS_FILE) as f:
    EXPERIMENTS_CONFIG = json.load(f)

DEFAULTS = EXPERIMENTS_CONFIG["defaults"]

NETWORK_CODES = {
    "Bio_ClinicalBERT": "CB",
    "BiomedNLP-PubMedBERT": "PMB",
    "BiomedNLP-BiomedBERT-base": "BMB",
    "BiomedNLP-BiomedBERT-large": "BMBL",
    "BioLinkBERT": "BLB",
    "biobert": "BB",
    "scibert": "SB",
    "bert-base": "BERT",
    "bert-large": "BERTL",
    "gatortron": "GT",
}


def _resolve_network_code(network_path):
    """Derive the short network code from a model path."""
    if network_path.endswith(".pth"):
        stem = Path(network_path).stem
        return stem.split("_")[0].split("-")[-1]
    for key, code in NETWORK_CODES.items():
        if key in network_path:
            return code
    raise ValueError(f"Cannot determine network code from: {network_path}")


def _batch_size_estimate(max_length):
    log_bs = -1.2209302325581395 * np.log(max_length) + 10.437506963898
    return int(2 ** round(np.log2(np.exp(log_bs))))


def _ensure_list(val):
    return val if isinstance(val, list) else [val]


def _flag_label(exclude_flag1, exclude_flag2):
    """Build a short label for the flag filter configuration.

    Uses '+' within a flag group and '.' between groups. Underscores in
    flag values are replaced with hyphens to avoid filename ambiguity.
    """
    parts = []
    if exclude_flag1:
        vals = sorted(v.replace("_", "-") for v in exclude_flag1.split(","))
        parts.append("f1" + "+".join(vals))
    if exclude_flag2:
        vals = sorted(v.replace("_", "-") for v in exclude_flag2.split(","))
        parts.append("f2" + "+".join(vals))
    return ".".join(parts) if parts else ""


def _expand_experiment(exp_id):
    """Expand an experiment definition into lists of ref files and model runs."""
    exp = EXPERIMENTS_CONFIG["experiments"][exp_id]

    methods = _ensure_list(exp.get("method", DEFAULTS["method"]))
    nwords_list = _ensure_list(exp.get("nwords", DEFAULTS["nwords"]))
    sections = _ensure_list(exp.get("section", DEFAULTS["section"]))
    networks = _ensure_list(exp.get("network", DEFAULTS["network"]))
    epochs_list = _ensure_list(exp.get("epochs", DEFAULTS["epochs"]))
    lr_list = _ensure_list(exp.get("learning_rate", DEFAULTS["learning_rate"]))
    sources = _ensure_list(exp.get("refsource", DEFAULTS["refsource"]))
    splits = _ensure_list(exp.get("split_method", DEFAULTS["split_method"]))
    batch_size_override = exp.get("batch_size", None)

    exclude_flag1 = exp.get("exclude_flag1", None)
    exclude_flag2 = exp.get("exclude_flag2", None)
    flaglabel = _flag_label(exclude_flag1, exclude_flag2)

    ref_files = set()
    model_runs = []

    for method, nwords, section, network, epochs, lr, refsource, split in itertools.product(
        methods, nwords_list, sections, networks, epochs_list, lr_list, sources, splits
    ):
        if flaglabel:
            ref_path = f"data/refs/ref{method}_nwords{nwords}_{flaglabel}_clinical_bert_reference_set_{section}.txt"
        else:
            ref_path = f"data/refs/ref{method}_nwords{nwords}_clinical_bert_reference_set_{section}.txt"
        ref_files.add(ref_path)

        max_length = 2 ** int(math.ceil(math.log2(2 * nwords)))
        batch_size = batch_size_override if batch_size_override else _batch_size_estimate(max_length)
        code = _resolve_network_code(network)

        # flagseed encodes the optional flag label + random seed
        flagseed = f"{flaglabel}_222" if flaglabel else "222"

        params = f"{method}-{section}-{nwords}-{refsource}_{flagseed}_{split}_{epochs}_{lr}_{max_length}_{batch_size}"
        bestepoch = f"models/bestepoch-bydrug-{code}_{params}.pth"

        model_runs.append({
            "ref_path": ref_path,
            "bestepoch": bestepoch,
            "params": params,
            "code": code,
            "method": method,
            "nwords": nwords,
            "section": section,
            "network": network,
            "epochs": epochs,
            "lr": lr,
            "refsource": refsource,
            "split": split,
            "max_length": max_length,
            "batch_size": batch_size,
            "flaglabel": flaglabel,
        })

    return list(ref_files), model_runs


# ---------------------------------------------------------------------------
# Determine targets from --config experiment=...
# ---------------------------------------------------------------------------

EXPERIMENT_ID = config.get("experiment", None)

ALL_REF_FILES = []
ALL_MODEL_RUNS = []

if EXPERIMENT_ID:
    if EXPERIMENT_ID == "all":
        exp_ids = list(EXPERIMENTS_CONFIG["experiments"].keys())
    else:
        exp_ids = [e.strip() for e in EXPERIMENT_ID.split(",")]
        unknown = [e for e in exp_ids if e not in EXPERIMENTS_CONFIG["experiments"]]
        if unknown:
            raise ValueError(
                f"Unknown experiment(s): {unknown}. "
                f"Available: {list(EXPERIMENTS_CONFIG['experiments'].keys())}"
            )

    for eid in exp_ids:
        refs, runs = _expand_experiment(eid)
        ALL_REF_FILES.extend(refs)
        ALL_MODEL_RUNS.extend(runs)

    # Deduplicate — overlapping experiments may produce identical model targets
    ALL_REF_FILES = list(set(ALL_REF_FILES))
    _seen = set()
    _deduped = []
    for run in ALL_MODEL_RUNS:
        if run["bestepoch"] not in _seen:
            _seen.add(run["bestepoch"])
            _deduped.append(run)
    ALL_MODEL_RUNS = _deduped

# Lookup from bestepoch output path → run config (for dependency resolution)
_RUN_BY_OUTPUT = {run["bestepoch"]: run for run in ALL_MODEL_RUNS}


# ---------------------------------------------------------------------------
# Dependency helpers
# ---------------------------------------------------------------------------

def _output_key_from_wildcards(wildcards):
    """Reconstruct the bestepoch output path from wildcards."""
    params = (
        f"{wildcards.method}-{wildcards.section}-{wildcards.nwords}-"
        f"{wildcards.refsource}_{wildcards.flagseed}_{wildcards.split}_"
        f"{wildcards.epochs}_{wildcards.lr}_{wildcards.maxlen}_{wildcards.batch}"
    )
    return f"models/bestepoch-bydrug-{wildcards.code}_{params}.pth"


def _resolve_network_from_wildcards(wildcards):
    """Find the network path for a given set of wildcards."""
    run = _RUN_BY_OUTPUT.get(_output_key_from_wildcards(wildcards))
    if run:
        return run["network"]
    from onsides.train import NETWORK_PATHS
    return str(NETWORK_PATHS.get(wildcards.code, f"models/{wildcards.code}"))


def _train_model_inputs(wildcards):
    """Determine inputs for train_model, including pretrained .pth dependencies."""
    ref = (
        f"data/refs/ref{wildcards.method}_nwords{wildcards.nwords}"
        f"_clinical_bert_reference_set_{wildcards.section}.txt"
    )
    inputs = {}

    run = _RUN_BY_OUTPUT.get(_output_key_from_wildcards(wildcards))
    if run:
        ref = run["ref_path"]
        if run["network"].endswith(".pth"):
            inputs["pretrained"] = run["network"]

    inputs["ref"] = ref
    return inputs


def _get_flag_label(wildcards):
    """Extract flag label from run config or return empty string."""
    run = _RUN_BY_OUTPUT.get(_output_key_from_wildcards(wildcards))
    if run:
        return run["flaglabel"]
    return ""


# ---------------------------------------------------------------------------
# Construct-ref helpers
# ---------------------------------------------------------------------------

def _build_flag_cli_args(flaglabel):
    """Convert a flaglabel like 'f1duplicate+unmapped.f2animal+drug-class' back to CLI args."""
    parts = flaglabel.split(".")
    args = []
    for part in parts:
        if part.startswith("f1"):
            values = part[2:].replace("+", ",").replace("-", "_")
            args.append(f"--exclude-flag1 {values}")
        elif part.startswith("f2"):
            values = part[2:].replace("+", ",").replace("-", "_")
            args.append(f"--exclude-flag2 {values}")
    return " ".join(args)


# ---------------------------------------------------------------------------
# Rules
# ---------------------------------------------------------------------------

# Wildcard constraints ensure unambiguous pattern matching.
# flagseed must start with 'f' (flag label) or be purely numeric (seed only).
wildcard_constraints:
    code = r"[A-Z]+",
    method = r"\d+",
    section = r"[A-Z]+",
    nwords = r"\d+",
    refsource = r"[a-z]+",
    flagseed = r"(?:f[12][a-z0-9+.\-]+(?:\.[a-z0-9+.\-]+)*_)?\d+",
    split = r"\d+|TAC",
    epochs = r"\d+",
    maxlen = r"\d+",
    batch = r"\d+",
    flaglabel = r"f[12][a-z0-9+.\-]+(?:\.[a-z0-9+.\-]+)*",

rule all:
    input:
        [r["bestepoch"] for r in ALL_MODEL_RUNS],
        [r["bestepoch"].replace("bestepoch", "final") for r in ALL_MODEL_RUNS],


rule construct_ref_nofilter:
    """Build a reference/training CSV from annotations + MedDRA vocab (no flag filtering)."""
    output: "data/refs/ref{method}_nwords{nwords}_clinical_bert_reference_set_{section}.txt"
    log: "log/train/construct_ref_{method}_{nwords}_{section}.log"
    shell:
        """
        uv run onsides-construct-ref \
            --method {wildcards.method} \
            --nwords {wildcards.nwords} \
            --section {wildcards.section} \
            --output {output} \
            2>&1 | tee {log}
        """


rule construct_ref_flagged:
    """Build a reference/training CSV with flag-based annotation filtering."""
    output: "data/refs/ref{method}_nwords{nwords}_{flaglabel}_clinical_bert_reference_set_{section}.txt"
    log: "log/train/construct_ref_{method}_{nwords}_{flaglabel}_{section}.log"
    params:
        flag_args=lambda wc: _build_flag_cli_args(wc.flaglabel)
    shell:
        """
        uv run onsides-construct-ref \
            --method {wildcards.method} \
            --nwords {wildcards.nwords} \
            --section {wildcards.section} \
            --output {output} \
            {params.flag_args} \
            2>&1 | tee {log}
        """


rule train_model:
    """Train a single model configuration."""
    input: unpack(_train_model_inputs)
    output:
        bestepoch="models/bestepoch-bydrug-{code}_{method}-{section}-{nwords}-{refsource}_{flagseed}_{split}_{epochs}_{lr}_{maxlen}_{batch}.pth",
        final="models/final-bydrug-{code}_{method}-{section}-{nwords}-{refsource}_{flagseed}_{split}_{epochs}_{lr}_{maxlen}_{batch}.pth",
        results="results/epoch-results-{code}_{method}-{section}-{nwords}-{refsource}_{flagseed}_{split}_{epochs}_{lr}_{maxlen}_{batch}.csv",
    log: "log/train/train_{code}_{method}-{section}-{nwords}-{refsource}_{flagseed}_{split}_{epochs}_{lr}_{maxlen}_{batch}.log"
    resources: gpu=1
    params:
        network=lambda wc: _resolve_network_from_wildcards(wc),
        flag_label=lambda wc: _get_flag_label(wc),
    shell:
        """
        uv run onsides-train \
            --ref {input.ref} \
            --network {params.network} \
            --refsource {wildcards.refsource} \
            --split-method {wildcards.split} \
            --epochs {wildcards.epochs} \
            --learning-rate {wildcards.lr} \
            --max-length {wildcards.maxlen} \
            --batch-size {wildcards.batch} \
            --flag-label '{params.flag_label}' \
            --ifexists overwrite \
            2>&1 | tee {log}
        """
